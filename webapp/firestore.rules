rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function platformAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid));
    }

    function hasPlatformInvite() {
      return signedIn() &&
        exists(/databases/$(database)/documents/platformInvites/$(request.auth.token.email));
    }

    function isOfficeMember(officeId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/offices/$(officeId)/members/$(request.auth.uid));
    }

    function isOfficeAdmin(officeId) {
      return isOfficeMember(officeId) &&
        get(/databases/$(database)/documents/offices/$(officeId)/members/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function officeActive(officeId) {
      return get(/databases/$(database)/documents/offices/$(officeId)).data.subscriptionStatus in ['TRIAL', 'ACTIVE'];
    }

    function hasOfficeInvite(officeId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/offices/$(officeId)/invites/$(request.auth.token.email));
    }

    match /platformAdmins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if platformAdmin();
    }

    match /platformInvites/{email} {
      allow read: if platformAdmin() || (signedIn() && request.auth.token.email == email);
      allow create, update: if platformAdmin();
      allow delete: if platformAdmin() || (signedIn() && request.auth.token.email == email);
    }

    match /userOfficeIndex/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update: if signedIn() && request.auth.uid == uid &&
        getAfter(/databases/$(database)/documents/offices/$(request.resource.data.officeId)/members/$(uid)).data.email == request.auth.token.email;
      allow delete: if platformAdmin();
    }

    match /offices/{officeId} {
      allow read: if isOfficeMember(officeId);
      allow create: if signedIn() && hasPlatformInvite() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOfficeAdmin(officeId) && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if platformAdmin();

      match /members/{uid} {
        allow read: if isOfficeMember(officeId);
        allow create: if signedIn() && request.auth.uid == uid &&
          (
            (hasPlatformInvite() && request.resource.data.role == 'ADMIN' && request.resource.data.email == request.auth.token.email) ||
            (hasOfficeInvite(officeId) && request.resource.data.email == request.auth.token.email) ||
            isOfficeAdmin(officeId)
          );
        allow update: if isOfficeAdmin(officeId) || request.auth.uid == uid;
        allow delete: if isOfficeAdmin(officeId);
      }

      match /invites/{email} {
        allow read: if isOfficeAdmin(officeId) || (signedIn() && request.auth.token.email == email);
        allow create, update: if isOfficeAdmin(officeId);
        allow delete: if isOfficeAdmin(officeId) || (signedIn() && request.auth.token.email == email);
      }

      match /contacts/{id} { allow read, write: if isOfficeMember(officeId) && officeActive(officeId); }
      match /serviceTypes/{id} { allow read, write: if isOfficeMember(officeId) && officeActive(officeId); }
      match /docTemplates/{id} { allow read, write: if isOfficeMember(officeId) && officeActive(officeId); }
      match /professionals/{id} { allow read, write: if isOfficeMember(officeId) && officeActive(officeId); }
      match /activity/{id} { allow read, write: if isOfficeMember(officeId) && officeActive(officeId); }
      match /chat/{id} { allow read, write: if isOfficeMember(officeId) && officeActive(officeId); }
      match /mevzuat/{id} {
        allow read: if isOfficeMember(officeId) && officeActive(officeId);
        allow write: if isOfficeAdmin(officeId) && officeActive(officeId);
      }
      match /notifications/{id} {
        allow read: if signedIn() && resource.data.forUid == request.auth.uid;
        allow create: if isOfficeMember(officeId) && officeActive(officeId);
        allow update, delete: if signedIn() && resource.data.forUid == request.auth.uid;
      }

      match /projects/{id} {
        allow read, write: if isOfficeMember(officeId) && officeActive(officeId);
        match /activities/{aid} {
          allow read, write: if isOfficeMember(officeId) && officeActive(officeId);
        }
      }
    }
  }
}
