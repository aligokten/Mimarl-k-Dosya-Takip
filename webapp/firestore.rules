rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isMember() {
      return signedIn() &&
        exists(/databases/$(database)/documents/members/$(request.auth.uid));
    }
    function isAdmin() {
      return isMember() &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Ofis: girisli herkes okuyabilir (davet kodu dogrulamasi icin);
    // ilk kez olusturan sahibi olur; sonrasinda yalnizca admin duzenler.
    match /office/{doc} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Admin ofisi düzenler ama owner (ofis sahibi) değiştirilemez.
      allow update: if isAdmin() &&
        request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if isAdmin();
    }

    function isOfficeOwner() {
      return signedIn() &&
        exists(/databases/$(database)/documents/office/main) &&
        get(/databases/$(database)/documents/office/main).data.ownerUid == request.auth.uid;
    }
    function hasInvite() {
      return signedIn() &&
        exists(/databases/$(database)/documents/invites/$(request.auth.token.email));
    }

    // Uyeler: her uye listeyi gorur. Kisi yalnizca kendi kaydini olusturabilir
    // ve bunu icin ya ofis sahibi olmali ya da e-postasina davet bulunmali.
    match /members/{uid} {
      allow read: if isMember();
      allow create: if signedIn() && request.auth.uid == uid &&
        (isOfficeOwner() || hasInvite());
      allow update: if request.auth.uid == uid || isAdmin();
      allow delete: if isAdmin();
    }

    // Davetler: yonetici e-posta ile calisan ekler. Davet dokumaninin kimligi
    // (dogrudan) calisanin e-postasidir. Yonetici tumunu yonetir; davet edilen
    // kisi yalnizca kendi davetini okuyup (ilk giriste) silebilir.
    match /invites/{email} {
      allow read: if isAdmin() ||
        (signedIn() && request.auth.token.email == email);
      allow create, update: if isAdmin();
      allow delete: if isAdmin() ||
        (signedIn() && request.auth.token.email == email);
    }

    match /contacts/{id} { allow read, write: if isMember(); }
    match /serviceTypes/{id} { allow read, write: if isMember(); }
    match /docTemplates/{id} { allow read, write: if isMember(); }
    match /professionals/{id} { allow read, write: if isMember(); }
    // Ofis geneli aktivite akışı ("Son İşlemler")
    match /activity/{id} { allow read, write: if isMember(); }
    // Ofis içi sohbet (kalıcı değil; her üye yazabilir/temizleyebilir)
    match /chat/{id} { allow read, write: if isMember(); }
    // Mevzuat PDF kayıtları: herkes görür, yalnızca yönetici ekler/siler.
    match /mevzuat/{id} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    match /projects/{id} {
      allow read, write: if isMember();
      match /activities/{aid} { allow read, write: if isMember(); }
    }

    match /notifications/{id} {
      allow read: if signedIn() && resource.data.forUid == request.auth.uid;
      allow create: if isMember();
      allow update, delete: if signedIn() && resource.data.forUid == request.auth.uid;
    }

    // İzin talepleri: tüm üyeler görebilir (yönetici takip eder); yalnızca
    // kendi talebini oluşturabilir, yönetici onaylar/reddeder/düzenler,
    // sahibi de kendi bekleyen talebini düzenleyip iptal edebilir.
    match /leaveRequests/{id} {
      allow read: if isMember();
      allow create: if isMember() &&
        request.resource.data.memberUid == request.auth.uid;
      allow update, delete: if isAdmin() ||
        (signedIn() && resource.data.memberUid == request.auth.uid &&
          resource.data.status == 'BEKLIYOR');
    }
  }
}
