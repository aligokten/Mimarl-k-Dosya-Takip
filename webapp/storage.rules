rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /offices/{officeId}/{allPaths=**} {
      allow read, write: if signedIn();
    }

    match /mevzuat/{allPaths=**} {
      allow read, write: if signedIn();
    }

    match /chat/{allPaths=**} {
      allow read, write: if signedIn();
    }
  }
}
