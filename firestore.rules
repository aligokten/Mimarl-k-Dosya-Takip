rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isLegacyMember() {
      return signedIn() &&
        exists(/databases/$(database)/documents/members/$(request.auth.uid));
    }

    function isLegacyAdmin() {
      return isLegacyMember() &&
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isLegacyOfficeOwner() {
      return signedIn() &&
        exists(/databases/$(database)/documents/office/main) &&
        get(/databases/$(database)/documents/office/main).data.ownerUid == request.auth.uid;
    }

    function hasLegacyInvite() {
      return signedIn() &&
        exists(/databases/$(database)/documents/invites/$(request.auth.token.email));
    }

    function myIndexPath() {
      return /databases/$(database)/documents/userOfficeIndex/$(request.auth.uid);
    }

    function hasUserIndex() {
      return signedIn() && exists(myIndexPath());
    }

    function myPrimaryOfficeId() {
      return get(myIndexPath()).data.primaryOfficeId;
    }


    function officeInvitePath() {
      return /databases/$(database)/documents/platformInvites/$(request.auth.token.email);
    }

    function hasOfficeCreateInvite() {
      return signedIn() &&
        request.auth.token.email != null &&
        exists(officeInvitePath()) &&
        (
          get(officeInvitePath()).data.status == "PENDING" ||
          get(officeInvitePath()).data.status == "ACTIVE"
        );
    }

    function canCreateNewOffice() {
      return signedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        hasOfficeCreateInvite() &&
        !hasUserIndex();
    }

    function isPlatformAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/platformAdmins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/platformAdmins/$(request.auth.uid)).data.active == true;
    }

    function isOfficeMemberDoc(officeId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/offices/$(officeId)/members/$(request.auth.uid));
    }

    function hasOfficeMembership(officeId) {
      return signedIn() &&
        hasUserIndex() &&
        myPrimaryOfficeId() == officeId &&
        isOfficeMemberDoc(officeId);
    }

    function isOfficeActive(officeId) {
      return exists(/databases/$(database)/documents/offices/$(officeId)) &&
        (
          get(/databases/$(database)/documents/offices/$(officeId)).data.accessStatus == null ||
          get(/databases/$(database)/documents/offices/$(officeId)).data.accessStatus == "ACTIVE" ||
          get(/databases/$(database)/documents/offices/$(officeId)).data.accessStatus == "TRIAL"
        );
    }

    function hasOfficeAccess(officeId) {
      return hasOfficeMembership(officeId) && isOfficeActive(officeId);
    }

    function employeeInvitePathForEmail(email) {
      return /databases/$(database)/documents/employeeInvites/$(email);
    }

    function hasEmployeeInviteForOffice(officeId) {
      return signedIn() &&
        request.auth.token.email != null &&
        exists(employeeInvitePathForEmail(request.auth.token.email)) &&
        get(employeeInvitePathForEmail(request.auth.token.email)).data.officeId == officeId;
    }

    function isOfficeOwner(officeId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/offices/$(officeId)) &&
        get(/databases/$(database)/documents/offices/$(officeId)).data.ownerUid == request.auth.uid;
    }

    match /office/{doc} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isLegacyAdmin() &&
        request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if isLegacyAdmin();
    }

    match /members/{uid} {
      allow read: if isLegacyMember();
      allow create: if signedIn() &&
        request.auth.uid == uid &&
        (isLegacyOfficeOwner() || hasLegacyInvite());
      allow update: if request.auth.uid == uid || isLegacyAdmin();
      allow delete: if isLegacyAdmin();
    }

    match /invites/{email} {
      allow read: if isLegacyAdmin() ||
        (signedIn() && request.auth.token.email == email);
      allow create, update: if isLegacyAdmin();
      allow delete: if isLegacyAdmin() ||
        (signedIn() && request.auth.token.email == email);
    }

    match /contacts/{id} {
      allow read, write: if isLegacyMember();
    }

    match /serviceTypes/{id} {
      allow read, write: if isLegacyMember();
    }

    match /docTemplates/{id} {
      allow read, write: if isLegacyMember();
    }

    match /professionals/{id} {
      allow read, write: if isLegacyMember();
    }

    match /activity/{id} {
      allow read, write: if isLegacyMember();
    }

    match /chat/{id} {
      allow read, write: if isLegacyMember();
    }

    match /mevzuat/{id} {
      allow read: if isLegacyMember();
      allow write: if isLegacyAdmin();
    }

    match /projects/{id} {
      allow read, write: if isLegacyMember();

      match /activities/{aid} {
        allow read, write: if isLegacyMember();
      }
    }

    match /notifications/{id} {
      allow read: if signedIn() &&
        resource.data.forUid == request.auth.uid;
      allow create: if isLegacyMember();
      allow update, delete: if signedIn() &&
        resource.data.forUid == request.auth.uid;
    }

    match /userOfficeIndex/{uid} {
      allow read: if signedIn() &&
        (request.auth.uid == uid || isPlatformAdmin());
      allow create, update: if signedIn() &&
        request.auth.uid == uid;
      allow create, update, delete: if isPlatformAdmin();
    }

    match /employeeInvites/{email} {
      allow get: if signedIn() &&
        request.auth.token.email == email;
      allow list: if isPlatformAdmin();
      allow create, update: if isPlatformAdmin() ||
        (
          signedIn() &&
          hasOfficeAccess(request.resource.data.officeId)
        );
      allow delete: if isPlatformAdmin() ||
        (
          signedIn() &&
          request.auth.token.email == email
        ) ||
        (
          signedIn() &&
          hasOfficeAccess(resource.data.officeId)
        );
    }

    match /platformAdmins/{uid} {
      allow read: if signedIn() &&
        (request.auth.uid == uid || isPlatformAdmin());
      allow write: if isPlatformAdmin();
    }

    match /platformInvites/{email} {
      allow get: if signedIn();
      allow list: if isPlatformAdmin();
      allow create, update, delete: if isPlatformAdmin();
    }

    match /platformLeads/{leadId} {
      allow read, create, update, delete: if isPlatformAdmin();
    }

    match /offices/{officeId} {
      allow read: if hasOfficeMembership(officeId) || isPlatformAdmin();

      allow create: if canCreateNewOffice();

      allow update, delete: if hasOfficeAccess(officeId) || isPlatformAdmin();

      match /members/{uid} {
        allow read: if hasOfficeMembership(officeId) ||
          isPlatformAdmin() ||
          (
            signedIn() &&
            request.auth.uid == uid
          ) ||
          (
            signedIn() &&
            request.auth.token.email != null &&
            resource.data.email == request.auth.token.email
          );

        allow create: if isPlatformAdmin() ||
          (
            signedIn() &&
            request.auth.uid == uid &&
            isOfficeOwner(officeId)
          ) ||
          (
            signedIn() &&
            request.auth.uid == uid &&
            hasEmployeeInviteForOffice(officeId)
          );

        allow update: if isPlatformAdmin() ||
          hasOfficeAccess(officeId) ||
          (
            signedIn() &&
            request.auth.uid == uid &&
            isOfficeMemberDoc(officeId)
          );

        allow delete: if isPlatformAdmin() || hasOfficeAccess(officeId);
      }

      match /invites/{email} {
        allow read: if hasOfficeAccess(officeId) ||
          isPlatformAdmin() ||
          (
            signedIn() &&
            request.auth.token.email == email
          );
        allow create, update, delete: if hasOfficeAccess(officeId) ||
          isPlatformAdmin();
      }

      match /mevzuat/{id} {
        allow read: if hasOfficeAccess(officeId) || isPlatformAdmin();
        allow write: if hasOfficeAccess(officeId) || isPlatformAdmin();
      }

      match /notifications/{id} {
        allow read: if signedIn() &&
          (
            isPlatformAdmin() ||
            (
              hasOfficeAccess(officeId) &&
              resource.data.forUid == request.auth.uid
            )
          );

        allow create: if hasOfficeAccess(officeId) || isPlatformAdmin();

        allow update, delete: if signedIn() &&
          (
            isPlatformAdmin() ||
            (
              hasOfficeAccess(officeId) &&
              resource.data.forUid == request.auth.uid
            )
          );
      }

      match /{document=**} {
        allow read, write: if hasOfficeAccess(officeId) || isPlatformAdmin();
      }
    }
  }
}
