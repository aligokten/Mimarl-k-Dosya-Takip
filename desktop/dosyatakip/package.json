{
  "name": "mimarlik-dosya-takip",
  "productName": "Mimarlık Ofisi Dosya Takip",
  "version": "1.0.0",
  "description": "Mimarlık ofisi proje ve evrak takip sistemi — Windows masaüstü uygulaması",
  "author": "SAGG İnşaat Mimarlık Akustik",
  "license": "UNLICENSED",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sagg.mimarlik-dosya-takip",
    "productName": "Mimarlık Ofisi Dosya Takip",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "offline.html",
      "icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mimarlık Dosya Takip",
      "artifactName": "MimarlikDosyaTakip-Kurulum-${version}.exe"
    }
  }
}
