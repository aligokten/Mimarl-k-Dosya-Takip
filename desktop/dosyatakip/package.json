{
  "name": "ruhsat360",
  "productName": "Ruhsat360",
  "version": "1.1.0",
  "description": "Ruhsat360 — mimarlık ofisi proje ve evrak takip sistemi (Windows masaüstü uygulaması)",
  "author": "SAGG İnşaat Mimarlık Akustik",
  "license": "UNLICENSED",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sagg.ruhsat360",
    "productName": "Ruhsat360",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "offline.html",
      "icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ruhsat360",
      "artifactName": "Ruhsat360-Kurulum-${version}.exe"
    }
  }
}
